---
const stages = [
	{
		label: "Dev output",
		href: "#deployment-pipeline",
		title: "Code, assets, and configuration produced by the development plane",
	},
	{
		label: "Storage",
		items: [
			{
				label: "Artifacts",
				href: "/artifacts/",
				title: "Cloudflare's git-compatible storage for development output",
			},
			{
				label: "Git repo",
				href: "#deployment-pipeline",
				title: "Existing enterprise code repositories",
			},
		],
	},
	{
		label: "Review",
		items: [
			{
				label: "Code review",
				href: "#deployment-pipeline",
				title: "Embed into existing code review flows for best practices",
			},
			{
				label: "Security scan",
				href: "#deployment-pipeline",
				title:
					"AI-assisted checks against OWASP Top 10 and dependency vulnerabilities",
			},
			{
				label: "CI/CD",
				href: "#deployment-pipeline",
				title:
					"Existing CI/CD pipelines run alongside Cloudflare-native services",
			},
		],
	},
	{
		label: "Deploy",
		href: "/cloudflare-for-platforms/workers-for-platforms/",
		title:
			"Applications deploy to Workers for Platforms for production hosting",
	},
];
---

<figure class="vibe-diagram" aria-label="Deployment pipeline architecture">
	<div class="pipeline-map">
		{
			stages.map((stage, i) => (
				<>
					{i > 0 && (
						<svg class="flow-arrow" viewBox="0 0 40 20" aria-hidden="true">
							<path d="M 0 10 L 30 10 M 24 4 L 32 10 L 24 16" class="arrow" />
						</svg>
					)}
					{"items" in stage ? (
						<div class="stage-box">
							<div class="stage-label">{stage.label}</div>
							<div class="stage-items">
								{stage.items!.map((item) => (
									<a class="tile" href={item.href} title={item.title}>
										{item.label}
									</a>
								))}
							</div>
						</div>
					) : (
						<a class="tile stage-tile" href={stage.href} title={stage.title}>
							{stage.label}
						</a>
					)}
				</>
			))
		}
	</div>
</figure>

<style>
	.vibe-diagram {
		--map-bg: light-dark(#fafafa, #0f0f10);
		--map-card: light-dark(#ffffff, #171719);
		--map-elevated: light-dark(#fafafa, #111113);
		--map-overlay: light-dark(#f5f5f5, #222226);
		--map-line: light-dark(rgb(0 0 0 / 12%), rgb(255 255 255 / 14%));
		--map-text: light-dark(#171717, #f5f5f5);
		--map-strong: light-dark(#525252, #a3a3a3);
		--map-subtle: light-dark(#737373, #d4d4d4);
		--map-brand: #f6821f;
		margin: 1rem 0;
		font-family: "Inter Variable", ui-sans-serif, system-ui, sans-serif;
		-webkit-font-smoothing: antialiased;
		letter-spacing: -0.01em;
	}
	.vibe-diagram a {
		color: inherit;
		text-decoration: none;
	}

	.pipeline-map {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 20px;
		border: 1px solid var(--map-line);
		border-radius: 12px;
		background:
			radial-gradient(circle, var(--map-line) 1px, transparent 1px),
			var(--map-bg);
		background-size: 12px 12px;
		overflow-x: auto;
	}

	.tile {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 8px 14px;
		border: 1px solid var(--map-line);
		border-radius: 9999px;
		background: var(--map-card);
		box-shadow: 0 2px 8px rgb(0 0 0 / 6%);
		color: var(--map-text);
		font-family:
			"Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 12px;
		font-weight: 500;
		white-space: nowrap;
		transition:
			background-color 150ms ease,
			border-color 150ms ease,
			transform 150ms ease;
	}
	.tile:hover {
		background: var(--map-overlay);
		border-color: color-mix(in srgb, var(--map-brand) 50%, var(--map-line));
		transform: translateY(-1px);
	}

	.stage-tile {
		padding: 14px 20px;
		min-height: 60px;
	}

	.stage-box {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 10px;
		border: 2px dashed var(--map-line);
		border-radius: 12px;
		background: var(--map-elevated);
		flex-shrink: 0;
	}
	.stage-label {
		color: var(--map-strong);
		font-family:
			"Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			monospace;
		font-size: 10px;
		font-weight: 500;
		text-transform: uppercase;
		margin-bottom: 2px;
	}
	.stage-items {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.flow-arrow {
		width: 32px;
		height: 16px;
		flex-shrink: 0;
	}
	.arrow {
		fill: none;
		stroke: var(--map-subtle);
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	@media (max-width: 58rem) {
		.pipeline-map {
			flex-direction: column;
			align-items: stretch;
		}
		.flow-arrow {
			transform: rotate(90deg);
			align-self: center;
		}
	}
</style>
