---
---

<figure class="vibe-diagram" aria-label="Development plane architecture">
	<div class="dev-map">
		<!-- Ingress -->
		<a class="tile ingress-tile" href="/cloudflare-one/policies/access/" title="Authenticates employees via corporate IdP and enforces who can build and what they can connect to" style="grid-area: access;">
			Access
		</a>

		<svg class="flow-arrow" style="grid-area: arrow1;" viewBox="0 0 40 20" aria-hidden="true"><path d="M 0 10 L 30 10 M 24 4 L 32 10 L 24 16" class="arrow"/></svg>

		<!-- Development container -->
		<div class="container-box" style="grid-area: container;">
			<div class="container-label">Development container</div>

			<div class="container-inner">
				<div class="dev-paths">
					<a class="tile" href="/sandbox/" title="Web-based chat UI with multi-agent orchestration that spins up a container with preview URLs">
						Frontend
					</a>
					<span class="path-or">or</span>
					<a class="tile" href="/containers/" title="CLI-based coding harness running inside a sandboxed container for IDE-based workflows">
						Agent flow
					</a>
				</div>

				<svg class="inner-arrow" viewBox="0 0 20 40" aria-hidden="true"><path d="M 10 0 L 10 30 M 4 24 L 10 32 L 16 24" class="arrow"/></svg>

				<a class="tile execution-tile" href="/sandbox/" title="Sandboxed container running AI-generated code with preview URLs, real-time streaming, and fast startup" style="width: 100%;">
					Container (Sandbox SDK)
				</a>

				<div class="query-line">
					<svg class="inner-arrow-down" viewBox="0 0 20 30" aria-hidden="true"><path d="M 10 0 L 10 22 M 4 16 L 10 24 L 16 16" class="arrow"/></svg>
					<a class="tile meta-tile" href="/d1/" title="Stores platform metadata: user profiles, sessions, cost tags, department and team permissions">
						D1 (metadata)
					</a>
				</div>
			</div>

			<div class="governance-bar">
				<div class="gov-label">LLM calls ↓</div>
				<a class="tile gov-tile" href="/ai-gateway/" title="Routes to approved LLM providers, enforces budget caps, logs every prompt and response, integrates DLP">
					AI Gateway
				</a>
				<div class="gov-label">Tool calls ↓</div>
				<a class="tile gov-tile" href="/cloudflare-one/access-controls/ai-controls/mcp-portals/" title="Tracks MCP tool usage across agent interactions for visibility and audit">
					MCP Portal
				</a>
			</div>
		</div>

		<svg class="flow-arrow" style="grid-area: arrow2;" viewBox="0 0 40 20" aria-hidden="true"><path d="M 0 10 L 30 10 M 24 4 L 32 10 L 24 16" class="arrow"/></svg>

		<!-- Egress -->
		<a class="tile egress-tile" href="/cloudflare-for-platforms/workers-for-platforms/configuration/outbound-workers/" title="Controls all egress, injects credentials so generated code never sees real secrets, enforces binding allowlists, connects to external APIs, Hyperdrive, and Tunnel" style="grid-area: egress;">
			Outbound Worker
		</a>
	</div>
</figure>

<style>
	.vibe-diagram {
		--map-bg: light-dark(#fafafa, #0f0f10);
		--map-card: light-dark(#ffffff, #171719);
		--map-elevated: light-dark(#fafafa, #111113);
		--map-overlay: light-dark(#f5f5f5, #222226);
		--map-line: light-dark(rgb(0 0 0 / 12%), rgb(255 255 255 / 14%));
		--map-text: light-dark(#171717, #f5f5f5);
		--map-strong: light-dark(#525252, #a3a3a3);
		--map-subtle: light-dark(#737373, #d4d4d4);
		--map-brand: #f6821f;
		--map-blue-bg: light-dark(#eff6ff, #172554);
		--map-blue-ring: light-dark(#93c5fd, #3b82f6);
		--map-blue-text: light-dark(#1d4ed8, #bfdbfe);
		margin: 1rem 0;
		font-family: "Inter Variable", ui-sans-serif, system-ui, sans-serif;
		-webkit-font-smoothing: antialiased;
		letter-spacing: -0.01em;
	}
	.vibe-diagram a { color: inherit; text-decoration: none; }

	.dev-map {
		display: grid;
		grid-template-columns: auto auto 1fr auto auto;
		grid-template-areas: "access arrow1 container arrow2 egress";
		align-items: center;
		gap: 12px;
		padding: 20px;
		border: 1px solid var(--map-line);
		border-radius: 12px;
		background: radial-gradient(circle, var(--map-line) 1px, transparent 1px), var(--map-bg);
		background-size: 12px 12px;
	}

	.tile {
		display: flex; align-items: center; justify-content: center;
		padding: 8px 14px;
		border: 1px solid var(--map-line); border-radius: 9999px;
		background: var(--map-card); box-shadow: 0 2px 8px rgb(0 0 0 / 6%);
		color: var(--map-text);
		font-family: "Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 12px; font-weight: 500; white-space: nowrap;
		transition: background-color 150ms ease, border-color 150ms ease, transform 150ms ease;
	}
	.tile:hover {
		background: var(--map-overlay);
		border-color: color-mix(in srgb, var(--map-brand) 50%, var(--map-line));
		transform: translateY(-1px);
	}

	.ingress-tile, .egress-tile {
		padding: 14px 18px;
		border-color: var(--map-blue-ring);
		background: var(--map-blue-bg);
		color: var(--map-blue-text);
	}

	.container-box {
		grid-area: container;
		border: 2px dashed var(--map-line);
		border-radius: 12px;
		padding: 12px;
		background: var(--map-elevated);
	}
	.container-label {
		color: var(--map-strong);
		font-family: "Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		font-size: 10px; font-weight: 500; text-transform: uppercase;
		margin-bottom: 10px;
	}

	.container-inner {
		display: flex; flex-direction: column; align-items: center; gap: 6px;
	}

	.dev-paths {
		display: flex; align-items: center; gap: 8px; width: 100%;
		justify-content: center;
	}
	.path-or {
		color: var(--map-subtle); font-size: 11px; font-style: italic;
	}

	.query-line {
		display: flex; flex-direction: column; align-items: center; gap: 2px;
	}

	.meta-tile {
		font-size: 11px; padding: 6px 12px;
		border-style: dashed;
	}

	.governance-bar {
		display: grid;
		grid-template-columns: auto 1fr auto 1fr;
		align-items: center;
		gap: 6px;
		margin-top: 10px;
		padding-top: 10px;
		border-top: 1px solid var(--map-line);
	}
	.gov-label {
		color: var(--map-subtle); font-size: 10px; text-align: center;
		font-family: "Paper Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
	}
	.gov-tile { font-size: 11px; justify-self: stretch; }

	.flow-arrow { width: 32px; height: 16px; flex-shrink: 0; }
	.inner-arrow { width: 16px; height: 24px; }
	.inner-arrow-down { width: 16px; height: 20px; }
	.arrow { fill: none; stroke: var(--map-subtle); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }

	.execution-tile { justify-content: center; }

	@media (max-width: 58rem) {
		.dev-map {
			grid-template-columns: 1fr;
			grid-template-areas: "access" "arrow1" "container" "arrow2" "egress";
			gap: 8px;
		}
		.flow-arrow { transform: rotate(90deg); justify-self: center; }
		.ingress-tile, .egress-tile { justify-self: center; }
	}
</style>
