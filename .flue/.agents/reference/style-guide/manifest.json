[
	{
		"id": "core-content",
		"file": "always/core-content.md",
		"load": "always",
		"when": "Always load for any selected MDX file with added content lines."
	},
	{
		"id": "links",
		"file": "conditional/links.md",
		"load": "conditional",
		"when": "Patch contains Markdown links, href=, http, root-relative paths, or anchors."
	},
	{
		"id": "code-blocks",
		"file": "conditional/code-blocks.md",
		"load": "conditional",
		"when": "Patch contains fenced code blocks."
	},
	{
		"id": "imports",
		"file": "conditional/imports.md",
		"load": "conditional",
		"when": "Patch contains import statements or JSX component tags."
	},
	{
		"id": "frontmatter",
		"file": "conditional/frontmatter.md",
		"load": "conditional",
		"when": "Patch changes frontmatter fields at the top of the file."
	},
	{
		"id": "component-anchor-heading",
		"file": "components/anchor-heading.md",
